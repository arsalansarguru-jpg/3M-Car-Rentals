# 3M Car Rentals — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is already excluded by .gitignore.

# Supabase Project URL (safe to share — no secrets here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — browser-safe, enforces Row Level Security
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase service_role key — SERVER ONLY, bypasses all RLS
# Never prefix with NEXT_PUBLIC_ — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key
